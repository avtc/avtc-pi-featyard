# Normalize all text files to LF line endings in the repo and on checkout.
# Binary files are auto-detected and left untouched by `text=auto`.
* text=auto eol=lf

# Explicit: source/docs/config are always LF text.
*.ts text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
